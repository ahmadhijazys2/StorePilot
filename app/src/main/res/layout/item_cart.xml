<?xml version="1.0" encoding="utf-8"?>
<!-- A single item row in the shopping cart -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Product image placeholder -->
        <View
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/product_image_placeholder"
            android:layout_marginEnd="12dp" />

        <!-- Product info + quantity controls -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Product name -->
            <TextView
                android:id="@+id/tvCartItemName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product Name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <!-- Unit price -->
            <TextView
                android:id="@+id/tvUnitPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00 each"
                android:textSize="12sp"
                android:textColor="@color/textSecondary"
                android:layout_marginBottom="8dp" />

            <!-- Quantity controls row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Minus button — decrease quantity -->
                <ImageButton
                    android:id="@+id/btnDecrease"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/btn_minus"
                    android:background="@drawable/circle_outline"
                    android:contentDescription="Decrease quantity" />

                <!-- Current quantity number -->
                <TextView
                    android:id="@+id/tvQuantity"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:gravity="center" />

                <!-- Plus button — increase quantity -->
                <ImageButton
                    android:id="@+id/btnIncrease"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/btn_plus"
                    android:background="@drawable/circle_cyan"
                    android:contentDescription="Increase quantity" />

            </LinearLayout>

        </LinearLayout>

        <!-- Right side: subtotal + remove button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="8dp">

            <!-- Line total for this item -->
            <TextView
                android:id="@+id/tvSubtotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorAccent"
                android:layout_marginBottom="8dp" />

            <!-- Remove button (trash icon) -->
            <ImageButton
                android:id="@+id/btnRemoveItem"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Remove from cart" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
