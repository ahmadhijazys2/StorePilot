<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_small"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_medium"
        android:gravity="center_vertical">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvSeasonName"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textStyle="bold" android:textSize="@dimen/text_size_subtitle"
                android:textColor="@color/textPrimary" />
            <TextView android:id="@+id/tvSeasonDates"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/textSecondary" android:textSize="@dimen/text_size_body" />
        </LinearLayout>

        <TextView android:id="@+id/tvSeasonActive"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/colorActive" android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
