<?xml version="1.0" encoding="utf-8"?>
<!-- A single conversation row in the manager support inbox list -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Customer avatar circle with initial -->
        <TextView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="C"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/circle_cyan"
            android:layout_marginEnd="12dp" />

        <!-- Customer name and message preview -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCustomerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Customer Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvMessagePreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Last message preview..."
                android:textSize="13sp"
                android:textColor="@color/textSecondary"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Arrow indicating there are more messages -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="20sp"
            android:textColor="@color/textSecondary" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
