<?xml version="1.0" encoding="utf-8"?>
<!-- Chat bubble for messages sent by the current user (right-aligned, cyan) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="end"
    android:padding="4dp">

    <!-- Bubble container — right side, capped width via layout_weight trick -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bubble_sent"
        android:padding="10dp">

        <!-- Message text -->
        <TextView
            android:id="@+id/tvMessageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Message"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp" />

        <!-- Timestamp shown below message -->
        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:00 PM"
            android:textSize="10sp"
            android:textColor="#CCFFFFFF"
            android:layout_gravity="end" />

        <!-- No sender name for sent messages -->
        <TextView
            android:id="@+id/tvSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
