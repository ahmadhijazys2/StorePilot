<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <!-- Required for showing notifications on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Required for AlarmManager to survive device reboots -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".StorePilotApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.StorePilot">

        <activity
            android:name=".auth.WelcomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".auth.LoginActivity" android:exported="false" />
        <activity android:name=".auth.RegisterActivity" android:exported="false" />
        <activity android:name=".auth.RoleSelectionActivity" android:exported="false" />
        <activity android:name=".auth.SetupActivity" android:exported="false" />
        <activity android:name=".MainActivity" android:exported="false" />
        <activity android:name=".customer.CustomerMainActivity" android:exported="false" />
        <activity android:name=".inventory.AddEditProductActivity" android:exported="false" />
        <activity android:name=".sales.AddSaleActivity" android:exported="false" />
        <activity android:name=".purchases.AddPurchaseActivity" android:exported="false" />
        <activity android:name=".marketing.AddMetricActivity" android:exported="false" />
        <activity android:name=".seasons.AddEditSeasonActivity" android:exported="false" />
        <activity android:name=".tasks.AddEditTaskActivity" android:exported="false" />

        <!-- BroadcastReceiver triggered by AlarmManager for low-stock checks -->
        <receiver
            android:name=".core.LowStockReceiver"
            android:exported="false" />

    </application>

</manifest>
