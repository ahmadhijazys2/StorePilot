<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Internet permission needed for future API or Firebase integration -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Read storage for image attachments in support chat -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.StorePilot">

        <!-- Welcome screen is now the launcher (entry point) -->
        <activity
            android:name=".auth.WelcomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login screen -->
        <activity
            android:name=".auth.LoginActivity"
            android:exported="false" />

        <!-- Registration screen (new) -->
        <activity
            android:name=".auth.RegisterActivity"
            android:exported="false" />

        <!-- Role selection screen (shown after Sign Up) -->
        <activity
            android:name=".auth.RoleSelectionActivity"
            android:exported="false" />

        <!-- First-time owner setup screen -->
        <activity
            android:name=".auth.SetupActivity"
            android:exported="false" />

        <!-- Manager/Owner main app -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Customer store app (new) -->
        <activity
            android:name=".customer.CustomerMainActivity"
            android:exported="false" />

        <!-- Product management screen -->
        <activity
            android:name=".inventory.AddEditProductActivity"
            android:exported="false" />

        <!-- Sales entry screen -->
        <activity
            android:name=".sales.AddSaleActivity"
            android:exported="false" />

        <!-- Purchase entry screen -->
        <activity
            android:name=".purchases.AddPurchaseActivity"
            android:exported="false" />

        <!-- Marketing metric screen -->
        <activity
            android:name=".marketing.AddMetricActivity"
            android:exported="false" />

        <!-- Season management screen -->
        <activity
            android:name=".seasons.AddEditSeasonActivity"
            android:exported="false" />

        <!-- Task management screen -->
        <activity
            android:name=".tasks.AddEditTaskActivity"
            android:exported="false" />

    </application>

</manifest>
